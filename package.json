{
  "name": "opencore-templates",
  "version": "1.0.0",
  "private": true,
  "description": "OpenCore server project",
  "scripts": {
    "dev": "opencore dev",
    "chat:dev": "pnpm --filter xchat-ui dev",
    "build": "tsc --noEmit && opencore build",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "check:fix:unsafe": "biome check --write --unsafe",
    "format": "biome format --write .",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write ."
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.11",
    "@open-core/cli": "^0.5.0",
    "@swc/core": "^1.15.8",
    "esbuild": "^0.27.2",
    "esbuild-plugin-swc": "^1.0.1",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@citizenfx/client": "2.0.22443-1",
    "@citizenfx/server": "2.0.22443-1",
    "@open-core/framework": "^0.3.2",
    "reflect-metadata": "^0.2.2"
  }
}
